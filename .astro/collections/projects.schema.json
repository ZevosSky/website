{
  "$ref": "#/definitions/projects",
  "definitions": {
    "projects": {
      "type": "object",
      "properties": {
        "title": {
          "type": "string"
        },
        "summary": {
          "type": "string"
        },
        "publishedDate": {
          "anyOf": [
            {
              "type": "string",
              "format": "date-time"
            },
            {
              "type": "string",
              "format": "date"
            },
            {
              "type": "integer",
              "format": "unix-time"
            }
          ]
        },
        "status": {
          "type": "string",
          "enum": [
            "active",
            "completed",
            "archived",
            "in-progress"
          ]
        },
        "tags": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": []
        },
        "coverImage": {
          "type": "string"
        },
        "featured": {
          "type": "boolean",
          "default": false
        },
        "links": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "label": {
                "type": "string"
              },
              "href": {
                "type": "string",
                "format": "uri"
              }
            },
            "required": [
              "label",
              "href"
            ],
            "additionalProperties": false
          },
          "default": []
        },
        "homepageWeight": {
          "type": "integer",
          "minimum": 0,
          "default": 99
        },
        "$schema": {
          "type": "string"
        }
      },
      "required": [
        "title",
        "summary",
        "publishedDate",
        "status",
        "coverImage"
      ],
      "additionalProperties": false
    }
  },
  "$schema": "http://json-schema.org/draft-07/schema#"
}