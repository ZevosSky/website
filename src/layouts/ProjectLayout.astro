---
import type { CollectionEntry } from "astro:content";
import BaseLayout from "./BaseLayout.astro";
import TagList from "../components/ui/TagList.astro";
import {
  formatDate,
  getRecommendedSidebarCount,
  getProjectSidebarProjects,
  getProjectStatusLabel
} from "../lib/content";

type Props = {
  project: CollectionEntry<"projects">;
};

const { project } = Astro.props;
const sidebarCount = getRecommendedSidebarCount(project.body);
const sidebarProjects = await getProjectSidebarProjects(project.slug, sidebarCount);
---

<BaseLayout title={project.data.title} description={project.data.summary}>
  <article class="entry shell">
    <header class="entry__hero">
      <div class="entry__heading">
        <p class="entry__eyebrow">Project</p>
        <h1>{project.data.title}</h1>
        <p class="entry__summary">{project.data.summary}</p>
        <div class="entry__meta">
          <span>{formatDate(project.data.publishedDate)}</span>
          <span>{getProjectStatusLabel(project.data.status)}</span>
        </div>
        <TagList tags={project.data.tags} />
        {
          project.data.links.length > 0 && (
            <div class="entry__links">
              {project.data.links.map((link) => <a href={link.href}>{link.label}</a>)}
            </div>
          )
        }
      </div>
      <button
        type="button"
        class="lightbox-trigger entry__image-trigger"
        data-lightbox-src={project.data.coverImage}
        data-lightbox-alt={project.data.title}
        aria-label={`Expand image for ${project.data.title}`}
      >
        <img src={project.data.coverImage} alt={project.data.title} class="entry__image" />
      </button>
    </header>
    <div class="entry__body-layout">
      <div class="entry__content prose">
        <slot />
      </div>
      {
        sidebarProjects.length > 0 && (
          <aside class="entry__sidebar">
            <p class="entry__sidebar-label">Other Projects</p>
            <div class="entry__sidebar-grid">
              {sidebarProjects.map((item) => (
                <a href={`/projects/${item.slug}`} class="entry__sidebar-card">
                  <img
                    src={item.data.coverImage}
                    alt={item.data.title}
                    class="entry__sidebar-image"
                    loading="lazy"
                  />
                  <span class="entry__sidebar-title">{item.data.title}</span>
                </a>
              ))}
            </div>
          </aside>
        )
      }
    </div>
  </article>
</BaseLayout>
