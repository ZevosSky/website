---
import BaseLayout from "../layouts/BaseLayout.astro";
import HeroSection from "../components/sections/HeroSection.astro";
import SectionIntro from "../components/sections/SectionIntro.astro";
import ProjectCard from "../components/ui/ProjectCard.astro";
import PostCard from "../components/ui/PostCard.astro";
import { siteConfig } from "../config/site";
import { getBlogPosts, getHomeProjects } from "../lib/content";

const projects = await getHomeProjects();
const posts = (await getBlogPosts()).slice(0, 2);
---

<BaseLayout>
  <HeroSection
    hero={siteConfig.hero}
    currentFocus={siteConfig.portfolio.showCurrentFocus ? siteConfig.currentFocus : undefined}
  />

  <section class="shell section">
    <SectionIntro
      eyebrow="Portfolio"
      title=""
      description=""
      actionHref="/projects"
      actionLabel="See all projects"
    />
    <div class="card-grid card-grid--projects">
      {projects.map((project) => <ProjectCard project={project} />)}
    </div>
  </section>

  <section class="shell section section--blog-strip">
    <SectionIntro
      eyebrow="Separate Blog"
      title={siteConfig.blog.title}
      description={siteConfig.blog.description}
      actionHref="/blog"
      actionLabel="Open the blog"
    />
    <div class="card-grid card-grid--blog">
      {posts.map((post) => <PostCard post={post} />)}
    </div>
  </section>
</BaseLayout>
