---
import { siteConfig } from "../../config/site";
---

<footer class="site-footer">
  <div class="shell site-footer__inner">
    <div>
      <p>{siteConfig.description}</p>
    </div>
    <ul class="site-footer__links" aria-label="Social links">
      {
        siteConfig.socials.map((social) => (
          <li>
            <a href={social.href} aria-label={social.label} title={social.label}>
              {
                social.label === "LinkedIn" ? (
                  <svg viewBox="0 0 24 24" aria-hidden="true" class="social-icon">
                    <path
                      fill="currentColor"
                      d="M6.94 8.5H3.56V20h3.38V8.5ZM5.25 3A2.03 2.03 0 0 0 3.2 5.03c0 1.1.9 2 2.02 2.02h.03A2.03 2.03 0 1 0 5.25 3ZM20.8 12.74c0-3.52-1.88-5.16-4.38-5.16-2.02 0-2.92 1.1-3.42 1.88V8.5H9.62c.04.64 0 11.5 0 11.5H13v-6.42c0-.34.02-.68.13-.92.27-.68.88-1.38 1.9-1.38 1.35 0 1.89 1.03 1.89 2.54V20h3.38v-7.26Z"
                    />
                  </svg>
                ) : (
                  <svg viewBox="0 0 24 24" aria-hidden="true" class="social-icon">
                    <path
                      fill="currentColor"
                      d="M12 .5A12 12 0 0 0 8.2 23.9c.6.1.82-.26.82-.58v-2.04c-3.34.72-4.04-1.42-4.04-1.42-.55-1.38-1.34-1.75-1.34-1.75-1.1-.75.08-.74.08-.74 1.2.09 1.83 1.24 1.83 1.24 1.08 1.85 2.83 1.31 3.52 1 .11-.79.42-1.31.76-1.61-2.67-.3-5.48-1.34-5.48-5.97 0-1.32.47-2.4 1.24-3.25-.13-.3-.54-1.53.12-3.18 0 0 1.01-.32 3.3 1.24a11.5 11.5 0 0 1 6 0c2.28-1.56 3.3-1.24 3.3-1.24.66 1.65.25 2.88.12 3.18.77.85 1.24 1.93 1.24 3.25 0 4.64-2.82 5.66-5.5 5.96.43.37.82 1.1.82 2.23v3.3c0 .32.22.7.83.58A12 12 0 0 0 12 .5Z"
                    />
                  </svg>
                )
              }
            </a>
          </li>
        ))
      }
    </ul>
  </div>
</footer>
